generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model File {
  id           String         @id @default(uuid())
  display_name String
  storage_name String
  user_id      String
  folder_id    String?
  size         BigInt
  created      DateTime       @default(now())
  folder       Folder?        @relation(fields: [folder_id], references: [id])
  user         User           @relation(fields: [user_id], references: [id])
  locations    FileLocation[]
}

model Folder {
  id           String   @id @default(uuid())
  display_name String
  user_id      String
  parent_id    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  files        File[]
  parent       Folder?  @relation("Subfolders", fields: [parent_id], references: [id])
  subfolders   Folder[] @relation("Subfolders")
  user         User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model User {
  id       String    @id @default(uuid())
  user     String    @unique
  email    String?   @unique
  pass     String
  nickname String
  fullName String?
  role     UserRole  @default(user)
  created  DateTime  @default(now())
  files    File[]
  folders  Folder[]
  sessions Session[]
  tokeners Tokener[]
}

/// Toten to change pass
model Tokener {
  id        String    @id @default(uuid())
  token     String
  user_id   String
  type      TokenType
  expireAt  DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [user_id], references: [id])
}

/// Session Data
model Session {
  id       String   @id @default(uuid())
  token    String
  user_id  String
  deviceId String
  exp      DateTime
  created  DateTime @default(now())
  user     User     @relation(fields: [user_id], references: [id])
}

/// State configuration for the node. Restart when connect node <-> gateway
model Nodes {
  id            String         @id @default(uuid())
  hardware_id   String
  current_ip    String
  port          Int
  name          String?
  total_space   BigInt?
  is_approved   Boolean        @default(false)
  last_connect  DateTime       @default(now())
  created_at    DateTime       @default(now())
  fileLocations FileLocation[]
  nodeHistories Node_History[]
}

/// Historical data of nodes
model Node_History {
  id           Int        @id @default(autoincrement())
  current_ip   String
  node_id      String
  status       NodeStates
  name         String?
  total_space  BigInt?
  used_space   BigInt?
  cpu_used     Float
  ram_used     BigInt
  ram_total    BigInt
  connect_from DateTime?
  recorced_at  DateTime   @default(now())
  node         Nodes      @relation(fields: [node_id], references: [id])
}

model FileLocation {
  id       String             @id @default(uuid())
  file_id  String
  nodes_id String
  status   FileLocationStates
  file     File               @relation(fields: [file_id], references: [id], onDelete: Cascade)
  nodes    Nodes              @relation(fields: [nodes_id], references: [id], onDelete: Cascade)
}

enum UserRole {
  admin
  user
}

enum TokenType {
  magicAuth
  passRes
}

enum NodeStates {
  online
  offline
  error
}

enum FileLocationStates {
  uploading
  done
  corrupted
}
